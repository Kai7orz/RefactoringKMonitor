<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="org.example.infrastructure.mybatis.mapper.UserMapper">
    <insert id="insert">
        insert into users (role_id,name, email) values(
                                                                                  #{user.roleId},
                                                                                  #{user.name},
                                                                                  #{user.email}
                                                                            )
    </insert>
    <select id="existsByEmail" resultType="boolean">
        select count(*) > 0 from users where email= #{email}
    </select>
    <select id="findUserByEmail" resultMap="userMap">
        select id,role_id,name,email from users where email = #{email}
    </select>
    <select id="findRoleById" resultMap="roleMap">
        select r.id, r.name from users u inner join role r on u.role_id=r.id where u.id = #{userId}
    </select>
    <delete id="delete">
        delete from users where id=#{userId}
    </delete>
    <resultMap id="userMap" type="org.example.core.user.User">
        <id column="id" property="id"/>
        <result column="role_id" property="roleId"/>
        <result column="name" property="name"/>
        <result column="email" property="email"/>
    </resultMap>
    <resultMap id="roleMap" type="org.example.application.Role">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
    </resultMap>
</mapper>
