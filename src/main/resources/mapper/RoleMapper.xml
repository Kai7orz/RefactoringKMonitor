<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd" >
<mapper namespace="org.example.infrastructure.mybatis.mapper.RoleMapper">
    <insert id="insert">
        insert into roles (name) values (#{roleName})
    </insert>
    <select id="findRoleByName" resultMap="roleMap">
        select * from roles where name=#{roleName}
    </select>
    <resultMap id="roleMap" type="org.example.application.Role">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
    </resultMap>
</mapper>
